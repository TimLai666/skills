# ============================================================
# .env.example  —  環境變數範本（此檔可進 git）
#
# 用法：
#   cp .env.example .env.development   # 填入 dev 專案的值
#   cp .env.example .env.production    # 填入 prod 專案的值
#   .env.development / .env.production 兩個檔案「絕不」進 git。
#
# 程式碼靠 APP_ENV 決定載入哪個檔，不設值時預設 development。
# ============================================================

# 目前環境（development / production），預設 development
APP_ENV=development

# --- Supabase 專案連線 ---
# 開發環境檔案填 dev 專案的值；正式環境檔案填 prod 專案的值。
# 兩個檔案使用相同的變數名，靠載入哪個檔來切換。
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# service_role 金鑰會繞過 RLS：只能在伺服器端使用，
# 絕不可出現在前端 bundle、client 程式碼或公開的地方。
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
